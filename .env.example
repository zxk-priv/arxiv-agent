# SiliconFlow / OpenAI-compatible settings
# 只有当你需要生成中文简介时，才需要填写下面三项。
SILICONFLOW_API_KEY=your_api_key_here
SILICONFLOW_MODEL=your_model_name_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B

# Local dataset / cache settings
ARXIV_AGENT_PAPER_DATASET_DIR=paper_datasets
ARXIV_AGENT_PDF_EXTRACT_PAGES=5

# App server settings
# Gradio 页面默认监听本机 6008 端口。
ARXIV_AGENT_HOST=127.0.0.1
ARXIV_AGENT_PORT=6008
